# .env.example — copy file ini ke .env dan isi dengan nilai yang sesuai
# cp .env.example .env

# ── Mode & Email ─────────────────────────────────────────────────────────────
# Mode default: "google" atau "tempmail"
# EMAIL_MODE=google

# File email untuk mode google (format: email:password per baris)
# EMAIL_FILE=emails.txt

# ── Browser ──────────────────────────────────────────────────────────────────
# Jalankan browser headless (true) atau tampilkan browser (false)
HEADLESS=true

# Aktifkan humanize — gerak mouse/keyboard seperti manusia
HUMANIZE=true

# ── Parallel & Delay ─────────────────────────────────────────────────────────
# Jumlah browser yang jalan paralel
CONCURRENCY=2

# Delay antar akun (detik), random antara MIN dan MAX
DELAY_MIN=3
DELAY_MAX=8

# ── Output ───────────────────────────────────────────────────────────────────
OUTPUT_FILE=results/accounts.csv

# ── Timeout ──────────────────────────────────────────────────────────────────
# Timeout navigasi halaman (detik)
PAGE_TIMEOUT=60

# Timeout tunggu email verifikasi (detik)
EMAIL_POLL_TIMEOUT=120

# Interval cek inbox (detik)
EMAIL_POLL_INTERVAL=5

# ── Tempmail Provider ─────────────────────────────────────────────────────────
# Provider untuk mode tempmail: "mailsac" atau "mailtm"
TEMPMAIL_PROVIDER=mailsac

# Mailsac API key — daftar gratis di https://mailsac.com
MAILSAC_API_KEY=your_mailsac_api_key_here

# ── CAPTCHA Solver ────────────────────────────────────────────────────────────
# CapSolver API key untuk solve Cloudflare Turnstile (mode tempmail)
# Daftar di https://capsolver.com
CAPSOLVER_API_KEY=your_capsolver_api_key_here

# ── Proxy ────────────────────────────────────────────────────────────────────
# Single proxy (opsional) — untuk semua akun
# PROXY=http://user:pass@host:port

# ── CloakBrowser Pro (opsional) ───────────────────────────────────────────────
# License key untuk CloakBrowser Pro binary (lebih baru, lebih stealth)
# CLOAKBROWSER_LICENSE_KEY=cb_xxxxxxxxxxxxxxxx
